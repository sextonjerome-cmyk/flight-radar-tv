# ---- airport data ----
# The default (Charleston) ships so the app works out of the box. Other airports and
# the heavy intermediates (.json, national CIFP, OSM cache) are regenerated on demand.
mapdata/*
!mapdata/.gitkeep
!mapdata/map_data.js
!mapdata/nav_data.js
!mapdata/charts_data.js
regions/

# ---- private / internal — never share ----
HANDOFF.md
CLAUDE.md
config.js.charleston.bak
*.bak

# ---- dev artifact (huge) ----
mockup.html

# ---- python ----
__pycache__/
*.pyc

# ---- OS cruft ----
.DS_Store
Thumbs.db
desktop.ini
